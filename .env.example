# --- Provider API keys ---
FRED_API_KEY=""
FMP_API_KEY=""
ALPHAVANTAGE_API_KEY=""

# --- On-chain portfolio (P-mode) ---
DEBANK_ACCESS_KEY=""
HELIUS_API_KEY=""
ZAPPER_API_KEY=""  # reserved; not used yet

# --- Cron / automation ---
# Protect admin/manual controls + HTTP cron endpoints with a bearer token.
CRON_ADMIN_BEARER="change-me"

# Queue mode:
# - inline: enqueue() immediately executes the task in-process (local dev only)
# - local_file: enqueue() appends to cron/.state/queue.jsonl; worker drains it
# - qstash: enqueue() pushes tasks to Upstash QStash (recommended for Vercel)
QUEUE_MODE="local_file"

# Where workers live (used by qstash enqueue to target your worker endpoint)
WORKER_BASE_URL="http://localhost:3000"
WORKER_TASK_PATH="/api/worker/consume"  # e.g. Next.js route

# Upstash QStash (optional)
QSTASH_TOKEN=""
QSTASH_URL="https://qstash.upstash.io"   # default

# Persistence mode:
# - file: local json files in cron/.state (default)
# - postgres: write job/task/series/axis state to Postgres
PERSISTENCE_MODE="file"

# Postgres (optional)
DATABASE_URL="postgresql://user:pass@host:5432/db"
DB_SCHEMA="cron"  # schema to use for cron tables, e.g. 'cron'

# Alerting (optional): Discord/Slack-style webhook
ALERT_WEBHOOK_URL=""
ALERT_WEBHOOK_TIMEOUT_MS="5000"

# Source toggles (optional overrides; source_state in DB should be authoritative in prod)
SOURCE_FRED_ENABLED="true"
SOURCE_COINGECKO_ENABLED="true"

# Freshness thresholds (minutes)
FRESHNESS_WARN_MINUTES_CRITICAL="120"   # warn after 2h
FRESHNESS_PAGE_MINUTES_CRITICAL="360"   # page after 6h
FRESHNESS_WARN_MINUTES_NORMAL="1440"    # 24h

# In prod, avoid logging secrets. This toggles extra debug logs locally.
CRON_DEBUG="false"
